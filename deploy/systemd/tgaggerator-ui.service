[Unit]
Description=TGaggregator Streamlit UI service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tgagg
Group=tgagg
WorkingDirectory=/opt/tgaggerator
EnvironmentFile=/opt/tgaggerator/.env
ExecStart=/usr/bin/env uv run streamlit run src/tgaggerator/ui/app.py --server.address 127.0.0.1 --server.port 8501
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
